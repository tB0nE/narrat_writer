# NARRATapi Configuration Template
# Copy this to .env and fill in your details.

API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions
API_MODEL=glm-4.7
API_KEY=YOUR_API_KEY_HERE

# NARRAT_MODE options: play, writer, developer
NARRAT_MODE=developer

# Folders
GARRAT_GAMES_DIR=games
GLOBAL_PROMPT_PREFIX=
