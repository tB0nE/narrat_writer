#!/usr/bin/env python
import os
import sys

# Ensure we are using the same environment that has our packages
# This helps if 'python3' points to system but 'python' points to pyenv
script_dir = os.path.dirname(os.path.abspath(__file__))
os.chdir(script_dir)

try:
    from client import main
except ImportError:
    # Fallback: try to re-run using the 'python' command in the shell
    # which is most likely to be the correct pyenv version
    print("[dim]Environment mismatch detected. Retrying with shell python...[/dim]")
    os.execvp("python", ["python", os.path.join(script_dir, "client.py")] + sys.argv[1:])

if __name__ == "__main__":
    main()
